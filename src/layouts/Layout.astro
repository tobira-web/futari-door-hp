---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ふたりの扉 | 前橋の結婚相談所',
  description = 'ふたりの扉は、群馬県前橋市のIBJ加盟結婚相談所です。プロの仲人があなたの「結婚したい」に、丁寧に向き合います。',
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="site-logo">ふたりの扉</a>
        <nav class="site-nav">
          <a href="/reasons">選ばれる理由</a>
          <a href="/pricing">料金プラン</a>
          <a href="/voice">会員の声</a>
          <a href="/profile">仲人プロフィール</a>
          <a href="/faq">よくある質問</a>
          <a href="/contact" class="btn nav-btn">無料相談を予約する</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p class="footer-logo">ふたりの扉</p>
        <nav class="footer-nav">
          <a href="/company">会社概要</a>
          <a href="/tokusho">特定商取引法の表記</a>
          <a href="/contact">お問い合わせ</a>
        </nav>
        <p class="footer-copy">&copy; 2026 ふたりの扉. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>

<style>
.site-header {
  background: var(--color-bg);
  border-bottom: 1px solid var(--color-line);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 68px;
}

.site-logo {
  font-family: var(--font-serif);
  font-size: 20px;
  color: var(--color-text);
  white-space: nowrap;
}

.site-nav {
  display: flex;
  align-items: center;
  gap: 28px;
  font-size: 14px;
  color: var(--color-text-sub);
}

.site-nav a:hover {
  color: var(--color-accent);
}

.nav-btn {
  font-size: 13px;
  padding: 10px 24px;
  min-width: auto;
  color: #fff !important;
}

.site-footer {
  background: var(--color-text);
  color: var(--color-line);
  padding: 48px 0 32px;
}

.footer-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}

.footer-logo {
  font-family: var(--font-serif);
  font-size: 18px;
  color: #fff;
}

.footer-nav {
  display: flex;
  gap: 28px;
  font-size: 13px;
}

.footer-nav a:hover {
  color: var(--color-accent);
}

.footer-copy {
  font-size: 12px;
  color: var(--color-text-sub);
}

@media (max-width: 768px) {
  .site-nav {
    display: none;
  }
  .footer-nav {
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
}
</style>
